{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "admin-api",
  "projectType": "application",
  "sourceRoot": "apps/admin-api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/admin-api/dist"],
      "options": {
        "command": "tsc --build",
        "cwd": "apps/admin-api"
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve": {
      "continuous": true,
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc --build --watch --preserveWatchOutput",
          "node --watch dist/main.js"
        ],
        "parallel": true,
        "cwd": "apps/admin-api"
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/apps/admin-api/dist/package.json",
        "{workspaceRoot}/apps/admin-api/dist/yarn.lock"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/admin-api/dist/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "docker-build": {
      "dependsOn": ["prune"],
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/admin-api/Dockerfile -t nx-sample-admin-api:latest .",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
