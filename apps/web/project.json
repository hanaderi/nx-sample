{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "web",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "targets": {
    "docker-build": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/web/Dockerfile -t nx-sample-web:latest .",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
