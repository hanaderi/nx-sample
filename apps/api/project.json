{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "api",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/api/dist"],
      "options": {
        "command": "tsc",
        "cwd": "apps/api"
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve": {
      "continuous": true,
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc --watch --preserveWatchOutput",
          "node --watch dist/main.js"
        ],
        "parallel": true,
        "cwd": "apps/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "vitest run --config ../../vitest.config.node.mts --root .",
        "cwd": "apps/api"
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/apps/api/dist/package.json",
        "{workspaceRoot}/apps/api/dist/yarn.lock"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/api/dist/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "docker-build": {
      "dependsOn": ["prune"],
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/api/Dockerfile -t nx-sample-api:latest .",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
