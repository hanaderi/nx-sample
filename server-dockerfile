FROM node:22.22.0-alpine
WORKDIR /app

ARG PORT
ARG APP_PATH
COPY apps/${APP_PATH}/dist/package.json ./package.json
COPY apps/${APP_PATH}/dist/yarn.lock ./yarn.lock
COPY apps/${APP_PATH}/dist/workspace_modules/ ./workspace_modules/
RUN yarn install --production --frozen-lockfile --non-interactive

COPY apps/${APP_PATH}/dist/ .

EXPOSE ${PORT}
CMD ["node", "main.js"]
