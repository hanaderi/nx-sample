{
  "extends": "../../tsconfig.cjs.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "types": ["vitest/globals", "node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "vitest.config.mts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "references": [
    { "path": "./tsconfig.lib.json" }
  ]
}
